# PM系统环境变量配置
# 复制此文件为 .env 并修改配置

# 前端目录（默认：同目录下的frontend/）
PM_FRONTEND_DIR=/path/to/pm-system/frontend

# 数据库路径（默认：./data/pm.db）
PM_DB_PATH=/path/to/data/pm.db

# 附件上传目录（默认：./data/attachments/）
PM_UPLOAD_DIR=/path/to/data/attachments

# Memos集成脚本（可选，留空则禁用）
MEMOS_SCRIPT=

# 服务端口（默认：5236）
PM_PORT=5236
